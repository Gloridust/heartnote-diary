# ========== 环境切换 ==========
# 可选: development | production
FLASK_ENV=development

# 数据库类型: sqlite | mysql
DB_TYPE=sqlite

# SQLite 配置（仅 DB_TYPE=sqlite 时生效）
SQLITE_PATH=instance/memoirai.db

# MySQL 配置（仅 DB_TYPE=mysql 时生效）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=memoirai
MYSQL_PASSWORD=changeme
MYSQL_DB=memoirai

# ========== 密钥 ==========
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-to-another-long-random-string
JWT_ACCESS_TOKEN_HOURS=8760

# ========== 管理员初始账号（首次启动自动创建） ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ========== LLM（豆包） ==========
ARK_API_KEY=
DOUBAO_MODEL=doubao-1-5-pro-32k-250115

# ========== STT（字节跳动） ==========
BYTEDANCE_APP_KEY=
BYTEDANCE_ACCESS_TOKEN=

# ========== 位置 + 天气（高德 Web 服务 Key） ==========
# 申请：https://console.amap.com/dev/key/app  类型选「Web 服务」
AMAP_KEY=

# ========== CORS ==========
CORS_ORIGINS=*
